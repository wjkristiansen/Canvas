{
  // Default scene shipped with CanvasTerrainViewer.
  // Paths are resolved relative to this file's directory.
  // CLI flags (--heightmap, --heightscale, --atlas-albedo, --atlas-orm, etc.)
  // override individual fields after this file is loaded.
  "scene": {
    "name": "default"
  },
  "tiles": [
    {
      "heightmap":   "default_heightmap.png",
      "dxy":         1.0,
      "heightScale": 64.0,
      "originXY":    [0, 0]
    }
  ],
  "material": {
    "atlasAlbedo":       "terrain_atlas_albedo.png",
    "atlasORM":          "terrain_atlas_orm.png",
    "atlasRepeatMeters": 8.0,
    "biome": {
      "sandMaxMeters":  4,
      "sandFadeMeters": 8,
      "snowMinMeters":  42,
      "snowFadeMeters": 52,
      "slopeRockMin":   0.10,
      "slopeRockMax":   0.30
    }
  },
  "camera": {
    // Start above the center of the tile, tilted forward to look out across
    // the terrain at roughly a 30-degree downward pitch.
    "startPositionXYZ": [0,   0, 150],
    "startLookAtXYZ":   [0, 500,   0],
    "fovDegrees":       60
  }
}
